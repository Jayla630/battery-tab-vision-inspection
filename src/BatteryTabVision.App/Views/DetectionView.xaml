<UserControl x:Class="BatteryTabVision.App.Views.DetectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:conv="clr-namespace:BatteryTabVision.App.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBool"/>
        <conv:BoolToOkNgColorConverter x:Key="OkColor"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- 图像区 + ROI 覆盖层 -->
        <Grid Grid.Row="0"
              Grid.Column="0"
              Margin="8"
              Background="#222">
            <Image Source="{Binding DisplayedImagePath}"
                   Stretch="Uniform"
                   x:Name="ImageElement"/>
            <Canvas Background="Transparent"
                    x:Name="RoiCanvas"
                    MouseDown="RoiCanvas_MouseDown"
                    MouseMove="RoiCanvas_MouseMove"
                    MouseUp="RoiCanvas_MouseUp">
                <Rectangle x:Name="RoiRect"
                           Stroke="Yellow"
                           StrokeThickness="2"
                           StrokeDashArray="4,2"
                           Fill="#33FFFF00"/>
            </Canvas>
        </Grid>

        <!-- 参数面板 + 历史列表 -->
        <Grid Grid.Row="0"
              Grid.Column="1"
              Margin="8,8,11,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"
                        MinHeight="120"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="检测参数"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="视觉引擎"
                               Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableEngines}"
                              SelectedItem="{Binding SelectedEngine, Mode=TwoWay}"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="产品型号"
                               Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableModels}"
                              SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                              Margin="0,0,0,12"/>
                    <Separator Margin="0,0,0,8"/>

                    <TextBlock Text="二值化阈值"/>
                    <Slider Value="{Binding BinaryThreshold, Mode=TwoWay}"
                            Minimum="0"
                            Maximum="255"
                            TickFrequency="10"/>
                    <TextBlock Text="{Binding BinaryThreshold}"
                               HorizontalAlignment="Right"/>

                    <TextBlock Text="最小轮廓面积"
                               Margin="0,8,0,0"/>
                    <Slider Value="{Binding MinContourArea, Mode=TwoWay}"
                            Minimum="100"
                            Maximum="10000"
                            TickFrequency="500"/>
                    <TextBlock Text="{Binding MinContourArea, StringFormat=F0}"
                               HorizontalAlignment="Right"/>

                    <TextBlock Text="像素/毫米标定"
                               Margin="0,8,0,0"/>
                    <Slider Value="{Binding PixelsPerMm, Mode=TwoWay}"
                            Minimum="5"
                            Maximum="50"
                            TickFrequency="1"/>
                    <TextBlock Text="{Binding PixelsPerMm, StringFormat=F2}"
                               HorizontalAlignment="Right"/>

                    <Separator Margin="0,8"/>
                    <TextBlock Text="公差范围 (mm)"
                               FontWeight="Bold"/>
                    <UniformGrid Columns="2"
                                 Margin="0,4">
                        <TextBlock Text="长度下限:"
                                   VerticalAlignment="Center"/>
                        <TextBox Text="{Binding LengthLowerLimit, StringFormat=F2, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Text="长度上限:"
                                   VerticalAlignment="Center"/>
                        <TextBox Text="{Binding LengthUpperLimit, StringFormat=F2, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Text="宽度下限:"
                                   VerticalAlignment="Center"/>
                        <TextBox Text="{Binding WidthLowerLimit, StringFormat=F2, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Text="宽度上限:"
                                   VerticalAlignment="Center"/>
                        <TextBox Text="{Binding WidthUpperLimit, StringFormat=F2, UpdateSourceTrigger=LostFocus}"/>
                    </UniformGrid>

                    <Separator Margin="0,8"/>
                    <Button Content="加载样本图"
                            Command="{Binding LoadSampleCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Height="36"
                            Margin="0,0,0,8"/>
                    <Button Content="加载缺陷样本"
                            Command="{Binding LoadBurrSampleCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Height="36"
                            Margin="0,0,0,8"/>
                    <Button Content="运行检测"
                            Command="{Binding RunDetectCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Height="36"/>
                </StackPanel>
            </ScrollViewer>

            <!-- 检测历史 ListBox 始终可见 -->
            <GroupBox Grid.Row="1"
                      Header="检测历史"
                      Margin="0,8,0,0">
                <ListBox ItemsSource="{Binding History}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch"/>
                            <Setter Property="Padding"
                                    Value="4,2"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- 第一行：时间戳 + OK/NG -->
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="{Binding TimestampDisplay}"
                                               Width="54"
                                            FontSize="11"
                                               Foreground="#888888"/>
                                    <TextBlock Text="{Binding IsOk, Converter={StaticResource OkColor}, ConverterParameter=text}"
                                               Foreground="{Binding IsOk, Converter={StaticResource OkColor}}"
                                               FontWeight="Bold"
                                            FontSize="11"/>
                                </DockPanel>
                                <!-- 第二行：尺寸 + 耗时（Summary 可能含缺陷信息，允许换行） -->
                                <TextBlock Text="{Binding Summary}"
                                           FontSize="10.5"
                                           Foreground="#444444"
                                           TextWrapping="Wrap"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>

        <!-- 状态栏跨两列 -->
        <StatusBar Grid.Row="1"
                   Grid.ColumnSpan="2">
            <StatusBarItem Content="{Binding StatusText}"/>
        </StatusBar>
    </Grid>
</UserControl>
