<UserControl x:Class="BatteryTabVision.App.Views.InspectionHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:conv="clr-namespace:BatteryTabVision.App.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <conv:EqualityToBooleanConverter x:Key="EqualityToBooleanConverter"/>
        <conv:BoolToOkNgColorConverter x:Key="OkColor"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 Row 0 -->
        <DockPanel Grid.Row="0"
                Margin="0,0,0,12">
            <TextBlock Text="检测历史记录"
                    FontSize="18"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"/>
            <Button Content="返回检测"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    Command="{Binding NavigateBackCommand}"
                    Style="{StaticResource BaseButtonStyle}"
                    Width="100"/>
        </DockPanel>

        <!-- 筛选栏 Row 1 -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="12"
                Margin="0,0,0,16">
            <WrapPanel Orientation="Horizontal">
                <!-- 结果筛选 -->
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,24,0">
                    <TextBlock Text="结果："
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"/>
                    <RadioButton Content="全部"
                            GroupName="Filter"
                            VerticalAlignment="Center"
                                 IsChecked="{Binding SelectedFilter, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=All, Mode=TwoWay}"
                                 Margin="0,0,12,0"/>
                    <RadioButton Content="OK"
                            GroupName="Filter"
                            VerticalAlignment="Center"
                                 IsChecked="{Binding SelectedFilter, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=OK, Mode=TwoWay}"
                                 Foreground="Green"
                            Margin="0,0,12,0"/>
                    <RadioButton Content="NG"
                            GroupName="Filter"
                            VerticalAlignment="Center"
                                 IsChecked="{Binding SelectedFilter, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=NG, Mode=TwoWay}"
                                 Foreground="Red"/>
                </StackPanel>

                <!-- 时间筛选 -->
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,24,0">
                    <TextBlock Text="开始日期："
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"/>
                    <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}"
                            Width="140"
                            Margin="0,0,12,0"/>
                    <TextBlock Text="结束日期："
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"/>
                    <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay}"
                            Width="140"/>
                </StackPanel>

                <!-- 操作按钮 -->
                <Button Content="查 询"
                        Command="{Binding QueryCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="80"
                        Margin="0,0,8,0"/>
                <Button Content="重 置"
                        Command="{Binding ResetCommand}"
                        Style="{StaticResource BaseButtonStyle}"
                        Width="80"/>

                <!-- 记录数 -->
                <TextBlock Text="{Binding StatusText}"
                        VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="16,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- DataGrid Row 2 -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="0"
                ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Records}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F8FAFC"
                      RowBackground="White"
                      BorderThickness="0"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="时间"
                            Width="140"
                            Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}"/>
                    <DataGridTextColumn Header="产品型号"
                            Width="120"
                            Binding="{Binding ProductModel}"/>
                    <DataGridTextColumn Header="引擎"
                            Width="100"
                            Binding="{Binding EngineName}"/>
                    <DataGridTemplateColumn Header="结果"
                            Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsOk, Converter={StaticResource OkColor}, ConverterParameter=text}"
                                           Foreground="{Binding IsOk, Converter={StaticResource OkColor}}"
                                           FontWeight="Bold"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="长度(mm)"
                            Width="90"
                            Binding="{Binding TabLengthMm, StringFormat=F2}"/>
                    <DataGridTextColumn Header="宽度(mm)"
                            Width="90"
                            Binding="{Binding TabWidthMm, StringFormat=F2}"/>
                    <DataGridTextColumn Header="缺陷数"
                            Width="70"
                            Binding="{Binding DefectCount}"/>
                    <DataGridTextColumn Header="耗时(ms)"
                            Width="80"
                            Binding="{Binding ElapsedMs}"/>
                    <DataGridTextColumn Header="SN"
                            Width="150"
                            Binding="{Binding SerialNo}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
