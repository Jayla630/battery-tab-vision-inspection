<UserControl x:Class="BatteryTabVision.App.Views.InspectionHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:conv="clr-namespace:BatteryTabVision.App.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <conv:EqualityToBooleanConverter x:Key="EqualityToBooleanConverter"/>
        <conv:BoolToOkNgColorConverter x:Key="OkColor"/>
        <conv:FileNameConverter x:Key="FileNameConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 Row 0 -->
        <DockPanel Grid.Row="0"
                Margin="0,0,0,12">
            <TextBlock Text="检测历史记录"
                    FontSize="18"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"/>
            <Button Content="返回检测"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    Command="{Binding NavigateBackCommand}"
                    Style="{StaticResource BaseButtonStyle}"
                    Width="100"/>
        </DockPanel>

        <!-- 筛选栏 Row 1 -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="12"
                Margin="0,0,0,16">
            <WrapPanel Orientation="Horizontal">
                <!-- 结果筛选 -->
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,24,0">
                    <TextBlock Text="结果："
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"/>
                    <RadioButton Content="全部"
                            GroupName="Filter"
                            VerticalAlignment="Center"
                                 IsChecked="{Binding SelectedFilter, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=All, Mode=TwoWay}"
                                 Margin="0,0,12,0"/>
                    <RadioButton Content="OK"
                            GroupName="Filter"
                            VerticalAlignment="Center"
                                 IsChecked="{Binding SelectedFilter, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=OK, Mode=TwoWay}"
                                 Foreground="Green"
                            Margin="0,0,12,0"/>
                    <RadioButton Content="NG"
                            GroupName="Filter"
                            VerticalAlignment="Center"
                                 IsChecked="{Binding SelectedFilter, Converter={StaticResource EqualityToBooleanConverter}, ConverterParameter=NG, Mode=TwoWay}"
                                 Foreground="Red"/>
                </StackPanel>

                <!-- 时间筛选 -->
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,24,0">
                    <TextBlock Text="开始日期："
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"/>
                    <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}"
                            Width="140"
                            Margin="0,0,12,0"/>
                    <TextBlock Text="结束日期："
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"/>
                    <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay}"
                            Width="140"/>
                </StackPanel>

                <!-- 操作按钮 -->
                <Button Content="查 询"
                        Command="{Binding QueryCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="80"
                        Margin="0,0,8,0"/>
                <Button Content="重 置"
                        Command="{Binding ResetCommand}"
                        Style="{StaticResource BaseButtonStyle}"
                        Width="80"/>

                <!-- 记录数 -->
                <TextBlock Text="{Binding StatusText}"
                        VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="16,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- DataGrid Row 2 -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="0"
                ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Records}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F8FAFC"
                      RowBackground="White"
                      BorderThickness="0"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      MouseDoubleClick="DataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="时间"
                            Width="140"
                            Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}"/>
                    <DataGridTextColumn Header="产品型号"
                            Width="120"
                            Binding="{Binding ProductModel}"/>
                    <DataGridTextColumn Header="引擎"
                            Width="100"
                            Binding="{Binding EngineName}"/>
                    <DataGridTemplateColumn Header="结果"
                            Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsOk, Converter={StaticResource OkColor}, ConverterParameter=text}"
                                           Foreground="{Binding IsOk, Converter={StaticResource OkColor}}"
                                           FontWeight="Bold"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="长度(mm)"
                            Width="90"
                            Binding="{Binding TabLengthMm, StringFormat=F2}"/>
                    <DataGridTextColumn Header="宽度(mm)"
                            Width="90"
                            Binding="{Binding TabWidthMm, StringFormat=F2}"/>
                    <DataGridTextColumn Header="缺陷数"
                            Width="70"
                            Binding="{Binding DefectCount}"/>
                    <DataGridTextColumn Header="耗时(ms)"
                            Width="80"
                            Binding="{Binding ElapsedMs}"/>
                    <DataGridTextColumn Header="SN"
                            Width="150"
                            Binding="{Binding SerialNo}"/>

                    <!-- 标注图（只显示文件名，Tooltip 显示完整路径） -->
                    <DataGridTemplateColumn Header="标注图" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AnnotatedImagePath,
                                              Converter={StaticResource FileNameConverter}}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding AnnotatedImagePath}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 算法参数（截断显示，Tooltip 显示完整 JSON） -->
                    <DataGridTemplateColumn Header="算法参数" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AlgorithmParamsJson}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding AlgorithmParamsJson}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 详情覆盖层 -->
        <Grid Visibility="{Binding IsDetailVisible,
                          Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#BB000000"
              Grid.RowSpan="3">
            <Border Background="White" CornerRadius="12"
                    MaxWidth="980" MaxHeight="680"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="24" Margin="40">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="检测详情" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="✕" Width="32" Height="32"
                                BorderThickness="0" Background="Transparent" Cursor="Hand"
                                Command="{Binding CloseDetailCommand}"
                                FontSize="16" Foreground="#6B7280"/>
                    </DockPanel>

                    <!-- 主体：左图右信息 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="420"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左：标注图 -->
                        <Border Grid.Column="0" Background="#111827" CornerRadius="8">
                            <Image Source="{Binding SelectedRecord.AnnotatedImagePath}"
                                   Stretch="Uniform" Margin="8"/>
                        </Border>

                        <!-- 右：详情字段 -->
                        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- 基本信息 -->
                                <TextBlock Text="基本信息" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="时间" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedRecord.Timestamp,
                                                      StringFormat=yyyy-MM-dd HH:mm:ss}"/>
                                </Grid>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="产品型号" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedRecord.ProductModel}"/>
                                </Grid>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="引擎" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedRecord.EngineName}"/>
                                </Grid>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="结果" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedRecord.IsOk,
                                                      Converter={StaticResource OkColor},
                                                      ConverterParameter=text}"
                                               Foreground="{Binding SelectedRecord.IsOk,
                                                            Converter={StaticResource OkColor}}"
                                               FontWeight="Bold"/>
                                </Grid>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="耗时" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedRecord.ElapsedMs,
                                                      StringFormat={}{0}ms}"/>
                                </Grid>

                                <!-- 尺寸测量 -->
                                <TextBlock Text="尺寸测量" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="极耳长度" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedRecord.TabLengthMm,
                                                      StringFormat={}{0:F2} mm}"/>
                                </Grid>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="极耳宽度" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedRecord.TabWidthMm,
                                                      StringFormat={}{0:F2} mm}"/>
                                </Grid>

                                <!-- 缺陷信息 -->
                                <TextBlock Text="缺陷信息" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="缺陷数量" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedRecord.DefectCount}"/>
                                </Grid>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="缺陷类型" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedRecord.DefectTypesJson}"
                                               TextWrapping="Wrap"/>
                                </Grid>

                                <!-- 算法参数快照 -->
                                <TextBlock Text="算法参数快照" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,0,0,8"/>
                                <Border Background="#F8FAFC" CornerRadius="6" Padding="12">
                                    <TextBlock Text="{Binding SelectedRecord.AlgorithmParamsJson}"
                                               TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontFamily="Consolas"/>
                                </Border>

                                <!-- 图像路径 -->
                                <TextBlock Text="标注图路径" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,16,0,8"/>
                                <TextBlock Text="{Binding SelectedRecord.AnnotatedImagePath}"
                                           TextWrapping="Wrap" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- 底部关闭按钮 -->
                    <Button Grid.Row="2" Content="关 闭"
                            Command="{Binding CloseDetailCommand}"
                            Style="{StaticResource BaseButtonStyle}"
                            Width="100" HorizontalAlignment="Right"
                            Margin="0,16,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
